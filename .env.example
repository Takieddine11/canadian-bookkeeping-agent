# Copy to .env and fill in. Never commit .env.

# --- Microsoft Teams / Azure Bot Service ---
# Create an Azure Bot resource; in its "Configuration" blade, note the App ID
# and generate a client secret. App type is SingleTenant for v1.
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_TENANTID=

# --- QuickBooks Online (Intuit Developer) ---
# Create an app at https://developer.intuit.com to get these.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8000/callback
QBO_ENVIRONMENT=sandbox          # sandbox | production
QBO_REALM_ID=                    # company ID, set per client
QBO_REFRESH_TOKEN=               # long-lived; regenerated periodically

# --- Google (optional: for Sheets/Drive deliverables) ---
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# --- Anthropic (optional: if tools need LLM calls) ---
ANTHROPIC_API_KEY=

# --- Runtime ---
LOG_LEVEL=INFO
TIMEZONE=America/Toronto
